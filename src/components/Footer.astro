---
const currentYear = new Date().getFullYear();
const APP_URL = 'https://ed-app-henna.vercel.app';
---

<footer class="bg-brand-dark text-slate-400">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="col-span-1 sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg class="w-7 h-7 text-primary-500" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="16" fill="currentColor" opacity="0.15"/>
            <path d="M16 8v16M8 16h16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="16" cy="16" r="7" stroke="currentColor" stroke-width="2"/>
          </svg>
          <span class="text-lg font-bold text-white">
            Encuentra<span class="text-primary-500">Doc</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed">
          La plataforma que conecta pacientes con especialistas de forma transparente y segura.
        </p>
      </div>

      <!-- Pacientes -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-3">Pacientes</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`${APP_URL}/signin`} class="hover:text-white transition-colors">Registrarse</a></li>
          <li><a href={APP_URL} class="hover:text-white transition-colors">Iniciar sesión</a></li>
          <li><a href="#como-funciona" class="hover:text-white transition-colors">Cómo funciona</a></li>
        </ul>
      </div>

      <!-- Doctores -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-3">Doctores</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`${APP_URL}/signin`} class="hover:text-white transition-colors">Crear perfil</a></li>
          <li><a href="#para-doctores" class="hover:text-white transition-colors">Ventajas</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-3">Legal</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacidad" class="hover:text-white transition-colors">Política de privacidad</a></li>
          <li><a href="/terminos" class="hover:text-white transition-colors">Términos de uso</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>© {currentYear} EncuentraDoc. Todos los derechos reservados.</p>
      <p>EncuentraDoc no proporciona servicios médicos. Es una plataforma de conexión entre pacientes y profesionales.</p>
    </div>
  </div>
</footer>
