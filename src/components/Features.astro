---
const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    title: "Ubicación de la consulta",
    description:
      "Visualiza en el mapa dónde trabaja cada especialista y encuentra el más cercano a ti.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
    title: "Mensajería directa",
    description:
      "Mensajería con texto enriquecido, emojis y envío de archivos. El doctor puede ver las fotos médicas que compartas.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
    title: "Comparte tu historial",
    description:
      "Sube fotos y documentación relevante para que tu especialista tenga toda la información antes de la consulta.",
  },
];
---

<section id="funcionalidades" class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-navy">
        Todo lo que necesitas en un solo lugar
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Diseñado para que encontrar y contactar con un especialista sea tan
        sencillo como debería ser.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        features.map((feature) => (
          <div class="card">
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
              style="background: var(--gradient-brand);"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                set:html={feature.icon}
              />
            </div>
            <div>
              <h3 class="text-base font-semibold text-brand-navy mb-2">
                {feature.title}
              </h3>
              <p class="text-sm text-slate-600 leading-relaxed">
                {feature.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
