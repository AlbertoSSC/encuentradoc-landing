---
import { APP_ROUTES } from '../config/app';
---

<section class="py-20 sm:py-28" style="background: var(--surface-inverse);">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
      Empieza hoy.
    </h2>
    <p class="mt-4 text-lg max-w-xl mx-auto" style="color: var(--text-on-inverse);">
      EncuentraDoc conecta pacientes con especialistas de forma directa y segura.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={APP_ROUTES.signin} class="w-full sm:w-auto btn-primary btn-lg" style="flex-direction: column;">
        <span>Soy paciente. Buscar especialista</span>
      </a>
      <a href={APP_ROUTES.signin} class="w-full sm:w-auto btn-outlined btn-lg">
        Soy doctor. Crear mi perfil
      </a>
    </div>

    <p class="mt-6 text-sm" style="color: var(--text-on-inverse); opacity: 0.7;">
      También puedes instalarlo directamente en tu móvil desde el navegador — sin App Store.
    </p>
  </div>
</section>
