---
const APP_URL = 'https://ed-app-henna.vercel.app';
---

<section class="relative pt-24 pb-20 sm:pt-32 sm:pb-28 overflow-hidden bg-gradient-to-b from-brand-light to-white">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-32 w-[600px] h-[600px] rounded-full bg-primary-100 opacity-40 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-primary-200 opacity-30 blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold text-primary-700 bg-primary-100 rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span>
        La plataforma de salud para pacientes y especialistas
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-brand-navy leading-tight tracking-tight">
        Conecta con el
        <span class="text-primary-600"> especialista</span>
        que necesitas
      </h1>

      <!-- Subheadline -->
      <p class="mt-6 text-lg sm:text-xl text-slate-600 leading-relaxed max-w-2xl mx-auto">
        Perfiles verificados con formación, experiencia y precios transparentes.
        Mensajería directa y gestión segura de tu historial médico.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${APP_URL}/signin`}
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary-600 rounded-xl hover:bg-primary-700 transition-all shadow-lg shadow-primary-200 hover:shadow-primary-300 hover:-translate-y-0.5"
        >
          Buscar un especialista
          <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="#para-doctores"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-brand-navy bg-white rounded-xl border border-slate-200 hover:border-primary-300 hover:bg-primary-50 transition-all"
        >
          Soy doctor
        </a>
      </div>

      <!-- Social proof -->
      <p class="mt-8 text-sm text-slate-400">
        Gratis para pacientes · Sin tarjeta de crédito
      </p>
    </div>

    <!-- App preview mockup -->
    <div class="relative mt-16 max-w-4xl mx-auto">
      <div class="bg-white rounded-2xl shadow-2xl shadow-slate-200 border border-slate-100 overflow-hidden">
        <!-- Browser bar -->
        <div class="flex items-center gap-1.5 px-4 py-3 bg-slate-50 border-b border-slate-100">
          <span class="w-3 h-3 rounded-full bg-red-300"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-300"></span>
          <span class="w-3 h-3 rounded-full bg-green-300"></span>
          <div class="flex-1 ml-4 h-5 bg-slate-200 rounded-full max-w-xs"></div>
        </div>
        <!-- Mockup content -->
        <div class="p-6 bg-gradient-to-br from-primary-50 to-white min-h-[280px] flex items-center justify-center">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 w-full max-w-2xl">
            {[
              { name: 'Dr. García López', spec: 'Cardiología', price: '80€' },
              { name: 'Dra. Martínez', spec: 'Dermatología', price: '65€' },
              { name: 'Dr. Fernández', spec: 'Traumatología', price: '90€' },
            ].map((doc) => (
              <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100">
                <div class="w-10 h-10 rounded-full bg-primary-100 mb-3 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <p class="text-sm font-semibold text-brand-navy">{doc.name}</p>
                <p class="text-xs text-primary-600 mt-0.5">{doc.spec}</p>
                <p class="text-xs text-slate-500 mt-2">Desde {doc.price}/consulta</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
