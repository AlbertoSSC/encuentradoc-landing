---
import { APP_ROUTES } from '../config/app';

const doctors = [
  { initials: 'GL', name: 'Dr. García López', spec: 'Cardiología', city: 'Madrid', price: '80' },
  { initials: 'M',  name: 'Dra. Martínez',    spec: 'Dermatología', city: 'Barcelona', price: '65' },
];
---

<section class="relative pt-28 pb-24 sm:pt-40 sm:pb-36 lg:min-h-screen lg:flex lg:items-center bg-gradient-to-b from-brand-light to-white">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="hero-blob-1 absolute -top-40 -right-32 w-[600px] h-[600px] rounded-full bg-primary-100 opacity-40 blur-3xl"></div>
    <div class="hero-blob-2 absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-primary-200 opacity-30 blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div data-hero-badge class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 text-xs font-semibold text-primary-700 bg-primary-100 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span>
          La plataforma de salud para pacientes y especialistas
        </div>

        <!-- Headline — overflow-hidden parents create the clip mask for text reveal -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-brand-navy leading-tight tracking-tight">
          <span class="block overflow-hidden">
            <span class="hero-line inline-block">Conecta con el</span>
          </span>
          <span class="block overflow-hidden">
            <span class="hero-line inline-block"><span class="text-primary-600">especialista</span> que necesitas</span>
          </span>
        </h1>

        <!-- Subheadline -->
        <p data-hero-sub class="mt-6 text-lg sm:text-xl text-slate-600 leading-relaxed">
          Perfiles verificados con número de colegiado. Búsqueda por especialidad y ubicación.
          Mensajería directa, precios transparentes y control total de tu privacidad.
        </p>

        <!-- CTAs -->
        <div data-hero-cta class="mt-10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <a href={APP_ROUTES.signin} class="w-full sm:w-auto btn-primary btn-lg">
            Buscar un especialista
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="#panel-especialista" class="w-full sm:w-auto btn-secondary btn-lg">
            Soy doctor
          </a>
        </div>

        <!-- Social proof -->
        <p data-hero-proof class="mt-8 text-sm text-slate-400">
          Sin intermediarios · Control total sobre tu privacidad
        </p>
      </div>

      <!-- Right: App preview mockup (3D tilt) -->
      <div class="mockup-scene" aria-hidden="true">
        <div data-hero-mockup class="mockup-3d">
          <div class="bg-white rounded-2xl shadow-2xl shadow-slate-200 border border-slate-100 overflow-hidden">
            <!-- Browser bar -->
            <div class="flex items-center gap-1.5 px-4 py-3 bg-slate-50 border-b border-slate-100">
              <span class="w-3 h-3 rounded-full bg-red-300"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-300"></span>
              <span class="w-3 h-3 rounded-full bg-green-300"></span>
              <div class="flex-1 ml-4 h-5 bg-slate-200 rounded-full max-w-xs text-[10px] text-slate-400 flex items-center px-3 select-none">
                encuentradoc.com/buscar
              </div>
            </div>

            <!-- Two-panel content -->
            <div class="flex min-h-[340px] pointer-events-none select-none">

              <!-- Left panel: Search + Results -->
              <div class="flex-1 p-4 bg-slate-50 border-r border-slate-100">
                <!-- Search bar -->
                <div class="flex gap-2 mb-3">
                  <div class="flex-1 flex items-center gap-2 bg-white border border-slate-200 rounded-lg px-3 py-2 text-xs text-slate-400">
                    <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    Busca por especialidad o ciudad...
                  </div>
                  <div class="bg-primary-600 text-white text-xs rounded-lg px-3 py-2 font-medium">Buscar</div>
                </div>

                <!-- Map placeholder -->
                <div class="relative bg-slate-200 rounded-lg h-20 mb-3 overflow-hidden flex items-center justify-center">
                  <!-- Subtle grid lines -->
                  <div class="absolute inset-0 opacity-30"
                    style="background-image: linear-gradient(rgba(100,116,139,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(100,116,139,0.3) 1px, transparent 1px); background-size: 20px 20px;"></div>
                  <svg class="w-6 h-6 text-primary-500 relative z-10" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                  <div class="absolute top-2 right-2 bg-white rounded-md px-1.5 py-0.5 text-[9px] text-slate-500 font-medium shadow-sm">
                    2 especialistas
                  </div>
                </div>

                <!-- Doctor cards -->
                <p class="text-[10px] text-slate-400 mb-2 font-medium">2 perfiles encontrados</p>
                <div class="space-y-2">
                  {doctors.map((doc) => (
                    <div class="bg-white rounded-xl p-3 border border-slate-100 shadow-sm">
                      <div class="flex items-start gap-2.5">
                        <!-- Avatar -->
                        <div class="w-9 h-9 rounded-full bg-primary-100 flex items-center justify-center shrink-0 text-xs font-bold text-primary-700">
                          {doc.initials}
                        </div>
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-1.5 flex-wrap">
                            <span class="text-xs font-semibold text-brand-navy">{doc.name}</span>
                            <!-- Verified badge -->
                            <span class="inline-flex items-center gap-0.5 text-[9px] font-semibold text-primary-700 bg-primary-50 border border-primary-200 rounded-full px-1.5 py-0.5">
                              <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                              </svg>
                              Verificado
                            </span>
                          </div>
                          <!-- Specialty + location + price -->
                          <div class="flex items-center gap-1.5 mt-1 flex-wrap">
                            <span class="text-[9px] font-medium text-primary-700 bg-primary-50 rounded-full px-1.5 py-0.5">{doc.spec}</span>
                            <span class="flex items-center gap-0.5 text-[9px] text-slate-400">
                              <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                              </svg>
                              {doc.city}
                            </span>
                            <span class="text-[9px] text-slate-500 ml-auto font-medium">Desde {doc.price}€</span>
                          </div>
                          <!-- Action buttons -->
                          <div class="flex gap-1.5 mt-2">
                            <div class="text-[9px] font-medium text-brand-navy bg-white border border-slate-200 rounded-md px-2 py-1">Ver perfil</div>
                            <div class="text-[9px] font-medium text-white bg-primary-600 rounded-md px-2 py-1">Contactar</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Right panel: Conversation thread (lg+) -->
              <div class="hidden lg:flex flex-col w-72 xl:w-80 bg-white">
                <!-- Thread header -->
                <div class="flex items-center gap-2.5 px-4 py-3 border-b border-slate-100 bg-slate-50">
                  <div class="w-7 h-7 rounded-full bg-primary-100 flex items-center justify-center text-[10px] font-bold text-primary-700 shrink-0">
                    GL
                  </div>
                  <div>
                    <p class="text-xs font-semibold text-brand-navy">Dr. García López</p>
                    <p class="text-[9px] text-primary-500 font-medium">● En línea</p>
                  </div>
                </div>

                <!-- Messages -->
                <div class="flex-1 p-3 space-y-3 overflow-hidden">
                  <!-- Doctor message -->
                  <div class="flex items-end gap-2">
                    <div class="w-5 h-5 rounded-full bg-primary-100 flex items-center justify-center text-[8px] font-bold text-primary-700 shrink-0">
                      GL
                    </div>
                    <div class="max-w-[80%]">
                      <div class="bg-slate-100 rounded-2xl rounded-bl-sm px-3 py-2 text-[10px] text-slate-700 leading-relaxed">
                        Hola, he revisado la documentación que compartiste. Te recomendaría una consulta presencial para valorar mejor el caso.
                      </div>
                      <p class="text-[8px] text-slate-400 mt-1 ml-1">10:24</p>
                    </div>
                  </div>

                  <!-- Patient message -->
                  <div class="flex items-end gap-2 flex-row-reverse">
                    <div class="w-5 h-5 rounded-full bg-primary-600 flex items-center justify-center text-[8px] font-bold text-white shrink-0">
                      Tú
                    </div>
                    <div class="max-w-[80%]">
                      <div class="bg-primary-600 rounded-2xl rounded-br-sm px-3 py-2 text-[10px] text-white leading-relaxed">
                        Muchas gracias doctor, ¿cuándo tendría disponibilidad?
                      </div>
                      <p class="text-[8px] text-slate-400 mt-1 mr-1 text-right">10:31</p>
                    </div>
                  </div>

                  <!-- Doctor message 2 -->
                  <div class="flex items-end gap-2">
                    <div class="w-5 h-5 rounded-full bg-primary-100 flex items-center justify-center text-[8px] font-bold text-primary-700 shrink-0">
                      GL
                    </div>
                    <div class="max-w-[80%]">
                      <div class="bg-slate-100 rounded-2xl rounded-bl-sm px-3 py-2 text-[10px] text-slate-700 leading-relaxed">
                        Esta semana tengo hueco el jueves a las 17:00. ¿Te viene bien?
                      </div>
                      <p class="text-[8px] text-slate-400 mt-1 ml-1">10:33</p>
                    </div>
                  </div>
                </div>

                <!-- Composer toolbar -->
                <div class="border-t border-slate-100 px-3 py-2.5 bg-white">
                  <div class="flex items-center gap-1 bg-slate-50 rounded-xl px-3 py-2">
                    <div class="text-[9px] text-slate-300 flex-1">Escribe un mensaje...</div>
                    <!-- Icons: T, paperclip, smile -->
                    <div class="flex items-center gap-2 text-slate-300">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h8"/>
                      </svg>
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                      </svg>
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <div class="w-5 h-5 rounded-lg bg-primary-600 flex items-center justify-center">
                        <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
