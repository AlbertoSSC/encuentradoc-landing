---
const patientSteps = [
  {
    number: '01',
    title: 'Crea tu perfil de paciente',
    description: 'Regístrate en minutos. Añade tu información básica y, si quieres, sube documentación relevante para que el especialista te conozca mejor.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>`,
  },
  {
    number: '02',
    title: 'Busca y explora especialistas',
    description: 'Filtra por especialidad y ubicación. Consulta el perfil completo: formación, experiencia, precios y localización de la consulta en el mapa.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`,
  },
  {
    number: '03',
    title: 'Contacta directamente',
    description: 'Envía una solicitud y empieza a comunicarte de forma segura a través de la mensajería integrada. Sin llamadas, sin intermediarios.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
  },
];

const doctorSteps = [
  {
    number: '01',
    title: 'Crea tu cuenta de especialista',
    description: 'Regístrate con email o Google. La cuenta de doctor es independiente: un mismo email no puede ser paciente y doctor a la vez.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    number: '02',
    title: 'Completa tu perfil profesional',
    description: 'Añade tu número de colegiado, formación académica y experiencia. Indica la ubicación de tus consultas en el mapa interactivo.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  },
  {
    number: '03',
    title: 'Publica tus precios y servicios',
    description: 'Define el precio de cada servicio y activa la financiación si la ofreces. Los pacientes ven esta información antes de contactarte.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>`,
  },
  {
    number: '04',
    title: 'Gestiona solicitudes y mensajes',
    description: 'Recibes solicitudes en tu panel. Tú decides si aceptar. Solo cuando aceptas se abre el canal de mensajería segura con el paciente.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>`,
  },
];
---

<section id="como-funciona" class="py-20 sm:py-28 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-navy">
        Cómo funciona
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Tanto si eres paciente como especialista, empezar es sencillo.
      </p>
    </div>

    <!-- CSS-only tab system -->
    <div class="how-it-works-tabs">
      <input type="radio" name="howitworks-tab" id="tab-patient" class="sr-only" checked />
      <input type="radio" name="howitworks-tab" id="tab-doctor" class="sr-only" />

      <!-- Tab labels -->
      <div class="flex justify-center mb-14">
        <div class="inline-flex bg-white rounded-xl border border-slate-200 p-1 shadow-sm">
          <label for="tab-patient" class="tab-label px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all text-slate-500 hover:text-brand-navy">
            Soy paciente
          </label>
          <label for="tab-doctor" class="tab-label px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all text-slate-500 hover:text-brand-navy">
            Soy doctor
          </label>
        </div>
      </div>

      <!-- ── Patient panel ─────────────────────────────────────────── -->
      <div id="panel-patient" class="tab-panel">
        <div data-hiw-timeline class="relative">

          <!-- Vertical path track -->
          <div class="absolute left-5 sm:left-6 top-6 bottom-6 w-px bg-slate-200 pointer-events-none" aria-hidden="true">
            <div data-hiw-progress class="absolute inset-x-0 top-0 w-full bg-primary-500 origin-top" style="height:100%;transform:scaleY(0)"></div>
          </div>

          <!-- Steps -->
          {patientSteps.map((step, i) => (
            <div data-hiw-step class="relative flex gap-6 sm:gap-10 pb-16 last:pb-0">

              <!-- Node -->
              <div class="shrink-0 flex flex-col items-center" style="width:2.75rem">
                <div data-hiw-node class="relative z-10 w-11 h-11 sm:w-12 sm:h-12 rounded-full flex items-center justify-center shadow-lg ring-4 ring-white" style="background:var(--gradient-brand)">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={step.icon} />
                </div>
              </div>

              <!-- Content -->
              <div data-hiw-step-content class="flex-1 pb-2">
                <!-- Ghost number -->
                <div class="flex items-start gap-3 mb-3">
                  <span class="text-7xl font-extrabold leading-none text-slate-100 select-none -mt-2">{step.number}</span>
                  <div class="pt-1">
                    <h3 class="text-lg sm:text-xl font-bold text-brand-navy">{step.title}</h3>
                    <p class="mt-1.5 text-sm sm:text-base text-slate-600 leading-relaxed">{step.description}</p>
                  </div>
                </div>

                <!-- Mockup image -->
                <div class="ml-0 sm:ml-2 mt-4">
                  {i === 0 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-50 border-b border-slate-100">
                        <div class="w-5 h-5 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                          <svg class="w-3 h-3 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        </div>
                        <span class="text-xs font-semibold text-brand-navy">Nuevo paciente</span>
                        <div class="ml-auto flex gap-1">
                          <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span>
                          <span class="w-1.5 h-1.5 rounded-full bg-primary-200"></span>
                          <span class="w-1.5 h-1.5 rounded-full bg-primary-100"></span>
                        </div>
                      </div>
                      <div class="p-4 space-y-3">
                        <div class="flex justify-center">
                          <div class="w-14 h-14 rounded-full bg-primary-50 border-2 border-dashed border-primary-200 flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                          </div>
                        </div>
                        <div class="space-y-2">
                          <div class="h-9 bg-slate-50 rounded-lg border border-slate-200 px-3 flex items-center">
                            <span class="text-[11px] text-slate-400">Nombre completo</span>
                          </div>
                          <div class="h-9 bg-slate-50 rounded-lg border border-slate-200 px-3 flex items-center">
                            <span class="text-[11px] text-slate-400">Correo electrónico</span>
                          </div>
                          <div class="h-9 rounded-lg flex items-center justify-center text-[11px] font-semibold text-white" style="background:var(--gradient-brand)">
                            Crear cuenta →
                          </div>
                        </div>
                      </div>
                    </div>
                  )}

                  {i === 1 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="flex items-center gap-2 px-3 py-2.5 bg-slate-50 border-b border-slate-100">
                        <svg class="w-3.5 h-3.5 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <span class="text-[11px] text-slate-500 flex-1">Cardiología · Madrid</span>
                        <div class="bg-primary-600 text-white text-[10px] font-medium rounded px-2 py-0.5">Buscar</div>
                      </div>
                      <div class="p-3 space-y-2">
                        <p class="text-[10px] text-slate-400 font-medium">3 especialistas encontrados</p>
                        {[
                          { initials: 'GL', name: 'Dr. García López', spec: 'Cardiología', price: '80€' },
                          { initials: 'MR', name: 'Dra. Molina Ruiz', spec: 'Cardiología', price: '70€' },
                        ].map((doc) => (
                          <div class="bg-white rounded-xl p-2.5 border border-slate-100 shadow-sm">
                            <div class="flex items-center gap-2">
                              <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-[9px] font-bold text-primary-700 shrink-0">{doc.initials}</div>
                              <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-1 flex-wrap">
                                  <span class="text-[10px] font-semibold text-brand-navy">{doc.name}</span>
                                  <span class="text-[8px] font-semibold text-primary-700 bg-primary-50 border border-primary-100 rounded-full px-1.5 py-0.5">✓ Verificado</span>
                                </div>
                                <div class="flex items-center gap-1.5 mt-0.5">
                                  <span class="text-[9px] font-medium text-primary-700 bg-primary-50 rounded-full px-1.5 py-0.5">{doc.spec}</span>
                                  <span class="text-[9px] text-slate-400 ml-auto">Desde {doc.price}</span>
                                </div>
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {i === 2 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="flex items-center gap-2.5 px-4 py-2.5 bg-slate-50 border-b border-slate-100">
                        <div class="w-7 h-7 rounded-full bg-primary-100 flex items-center justify-center text-[9px] font-bold text-primary-700 shrink-0">GL</div>
                        <div>
                          <p class="text-xs font-semibold text-brand-navy">Dr. García López</p>
                          <p class="text-[9px] text-primary-500 font-medium">● En línea</p>
                        </div>
                      </div>
                      <div class="p-3 space-y-2.5">
                        <div class="flex items-end gap-1.5">
                          <div class="w-5 h-5 rounded-full bg-primary-100 flex items-center justify-center text-[7px] font-bold text-primary-700 shrink-0">GL</div>
                          <div class="bg-slate-100 rounded-2xl rounded-bl-sm px-3 py-2 text-[10px] text-slate-700 max-w-[80%] leading-relaxed">Hola, ¿en qué puedo ayudarle?</div>
                        </div>
                        <div class="flex items-end gap-1.5 flex-row-reverse">
                          <div class="w-5 h-5 rounded-full bg-primary-600 flex items-center justify-center text-[7px] font-bold text-white shrink-0">Tú</div>
                          <div class="bg-primary-600 rounded-2xl rounded-br-sm px-3 py-2 text-[10px] text-white max-w-[80%] leading-relaxed">Quería consultar mis resultados recientes.</div>
                        </div>
                        <div class="flex items-end gap-1.5">
                          <div class="w-5 h-5 rounded-full bg-primary-100 flex items-center justify-center text-[7px] font-bold text-primary-700 shrink-0">GL</div>
                          <div class="bg-slate-100 rounded-2xl rounded-bl-sm px-3 py-2 text-[10px] text-slate-700 max-w-[80%] leading-relaxed">Claro, tengo su historial aquí.</div>
                        </div>
                        <div class="flex items-center gap-1 bg-slate-50 rounded-xl px-3 py-2 mt-1">
                          <span class="text-[9px] text-slate-300 flex-1">Escribe un mensaje...</span>
                          <div class="w-5 h-5 rounded-lg bg-primary-600 flex items-center justify-center">
                            <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>

      <!-- ── Doctor panel ──────────────────────────────────────────── -->
      <div id="panel-doctor" class="tab-panel">
        <div data-hiw-timeline class="relative">

          <!-- Vertical path track -->
          <div class="absolute left-5 sm:left-6 top-6 bottom-6 w-px bg-slate-200 pointer-events-none" aria-hidden="true">
            <div data-hiw-progress class="absolute inset-x-0 top-0 w-full bg-primary-500 origin-top" style="height:100%;transform:scaleY(0)"></div>
          </div>

          {doctorSteps.map((step, i) => (
            <div data-hiw-step class="relative flex gap-6 sm:gap-10 pb-16 last:pb-0">

              <div class="shrink-0 flex flex-col items-center" style="width:2.75rem">
                <div data-hiw-node class="relative z-10 w-11 h-11 sm:w-12 sm:h-12 rounded-full flex items-center justify-center shadow-lg ring-4 ring-white" style="background:var(--gradient-brand)">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={step.icon} />
                </div>
              </div>

              <div data-hiw-step-content class="flex-1 pb-2">
                <div class="flex items-start gap-3 mb-3">
                  <span class="text-7xl font-extrabold leading-none text-slate-100 select-none -mt-2">{step.number}</span>
                  <div class="pt-1">
                    <h3 class="text-lg sm:text-xl font-bold text-brand-navy">{step.title}</h3>
                    <p class="mt-1.5 text-sm sm:text-base text-slate-600 leading-relaxed">{step.description}</p>
                  </div>
                </div>

                <div class="ml-0 sm:ml-2 mt-4">
                  {i === 0 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="flex items-center gap-2 px-4 py-2.5 bg-brand-navy">
                        <span class="text-xs font-bold text-white">Encuentra<span class="text-primary-400">Doc</span></span>
                        <span class="ml-auto text-[9px] font-semibold text-primary-300 bg-primary-900/40 rounded-full px-2 py-0.5">Especialista</span>
                      </div>
                      <div class="p-4 space-y-2">
                        <div class="h-9 bg-slate-50 rounded-lg border border-slate-200 px-3 flex items-center">
                          <span class="text-[11px] text-slate-400">Nombre y apellidos</span>
                        </div>
                        <div class="h-9 bg-slate-50 rounded-lg border border-slate-200 px-3 flex items-center">
                          <span class="text-[11px] text-slate-400">Número de colegiado</span>
                        </div>
                        <div class="h-9 bg-slate-50 rounded-lg border border-slate-200 px-3 flex items-center">
                          <span class="text-[11px] text-slate-400">Especialidad médica</span>
                        </div>
                        <div class="h-9 rounded-lg flex items-center justify-center text-[11px] font-semibold text-white" style="background:var(--gradient-brand)">
                          Registrar cuenta →
                        </div>
                      </div>
                    </div>
                  )}

                  {i === 1 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="px-4 py-3 border-b border-slate-100">
                        <div class="flex items-center gap-3">
                          <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center text-xs font-bold text-primary-700 shrink-0">GL</div>
                          <div>
                            <p class="text-xs font-bold text-brand-navy">Dr. García López</p>
                            <p class="text-[9px] text-slate-500">Cardiólogo · Madrid</p>
                          </div>
                        </div>
                        <div class="mt-3">
                          <div class="flex justify-between mb-1">
                            <span class="text-[9px] text-slate-500">Perfil completado</span>
                            <span class="text-[9px] font-bold text-primary-600">75%</span>
                          </div>
                          <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                            <div class="h-full w-3/4 rounded-full bg-primary-500"></div>
                          </div>
                        </div>
                      </div>
                      <div class="p-3 space-y-2">
                        {[
                          { done: true,  label: 'Número de colegiado' },
                          { done: true,  label: 'Formación académica' },
                          { done: false, label: 'Fotografía profesional' },
                        ].map((item) => (
                          <div class="flex items-center gap-2.5">
                            <div class={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 ${item.done ? 'bg-primary-100' : 'bg-slate-100'}`}>
                              {item.done && <svg class="w-3 h-3 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>}
                            </div>
                            <span class={`text-[11px] ${item.done ? 'text-brand-navy font-medium' : 'text-slate-400'}`}>{item.label}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {i === 2 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-50 border-b border-slate-100">
                        <svg class="w-3.5 h-3.5 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                        <span class="text-xs font-semibold text-brand-navy">Mis servicios</span>
                      </div>
                      <div class="p-3 space-y-1.5">
                        {[
                          { name: 'Primera consulta',       price: '80€' },
                          { name: 'Consulta de seguimiento', price: '60€' },
                          { name: 'Consulta online',         price: '50€' },
                        ].map((svc) => (
                          <div class="flex items-center gap-2 p-2.5 bg-slate-50 rounded-lg border border-slate-100">
                            <p class="text-[11px] font-medium text-brand-navy flex-1 truncate">{svc.name}</p>
                            <span class="text-[11px] font-bold text-primary-600 shrink-0">{svc.price}</span>
                            <div class="w-7 h-4 bg-primary-500 rounded-full flex items-center px-0.5 shrink-0">
                              <div class="w-3 h-3 bg-white rounded-full ml-auto"></div>
                            </div>
                          </div>
                        ))}
                        <div class="flex items-center gap-2 p-2.5 border border-dashed border-slate-200 rounded-lg">
                          <span class="text-[10px] text-slate-400">+ Añadir servicio</span>
                        </div>
                      </div>
                    </div>
                  )}

                  {i === 3 && (
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg overflow-hidden select-none pointer-events-none max-w-sm">
                      <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-50 border-b border-slate-100">
                        <span class="text-xs font-semibold text-brand-navy flex-1">Solicitudes recibidas</span>
                        <span class="text-[9px] font-bold text-white bg-red-500 rounded-full px-1.5 py-0.5">2</span>
                      </div>
                      <div class="p-3 space-y-2">
                        {[
                          { initials: 'AP', name: 'Ana Pérez',  msg: 'Buenos días, quería consultarle sobre mis resultados...', color: 'bg-primary-100 text-primary-700' },
                          { initials: 'CM', name: 'Carlos M.', msg: 'Tengo los resultados de la analítica reciente...', color: 'bg-slate-200 text-slate-600' },
                        ].map((req) => (
                          <div class="p-2.5 bg-slate-50 rounded-xl border border-slate-100">
                            <div class="flex items-start gap-2">
                              <div class={`w-7 h-7 rounded-full ${req.color} flex items-center justify-center text-[9px] font-bold shrink-0`}>{req.initials}</div>
                              <div class="flex-1 min-w-0">
                                <p class="text-[10px] font-semibold text-brand-navy">{req.name}</p>
                                <p class="text-[9px] text-slate-400 truncate mt-0.5">{req.msg}</p>
                              </div>
                            </div>
                            <div class="flex gap-1.5 mt-2">
                              <div class="flex-1 text-[9px] font-medium text-slate-500 border border-slate-200 rounded-md py-1 text-center">Rechazar</div>
                              <div class="flex-1 text-[9px] font-medium text-white bg-primary-600 rounded-md py-1 text-center">Aceptar</div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tab-panel { display: none; }

  #tab-patient:checked ~ #panel-patient { display: block; }
  #tab-doctor:checked  ~ #panel-doctor  { display: block; }

  #tab-patient:checked ~ div label[for="tab-patient"],
  #tab-doctor:checked  ~ div label[for="tab-doctor"] {
    background: var(--gradient-brand);
    color: var(--text-on-brand);
    box-shadow: var(--shadow-sm);
  }
</style>
